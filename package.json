{
  "name": "kover",
  "version": "1.0.0",
  "description": "Dead simple drag-and-drop cover art tagger for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "music-tag-native": "^1.0.0",
    "music-tag-native-darwin-arm64": "^1.0.0",
    "music-tag-native-darwin-x64": "^1.0.0",
    "music-tag-native-win32-arm64-msvc": "^1.0.0",
    "music-tag-native-win32-x64-msvc": "^1.0.0",
    "node-id3": "^0.2.6"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.teekatas.kover",
    "productName": "Kover",
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg"
      ],
      "icon": "icon.png",
      "identity": null
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
