{
  "name": "kover",
  "version": "1.0.0",
  "description": "Dead simple drag-and-drop cover art tagger",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "music-tag-native": "^1.0.0",
    "music-tag-native-darwin-arm64": "^1.0.0",
    "music-tag-native-darwin-x64": "^1.0.0",
    "music-tag-native-win32-arm64-msvc": "^1.0.0",
    "music-tag-native-win32-x64-msvc": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.teekatas.kover",
    "productName": "Kover",
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg"
      ],
      "icon": "icon.png",
      "identity": null,
      "files": [
        "**/*",
        "!node_modules/music-tag-native-win32-*"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png",
      "files": [
        "**/*",
        "!node_modules/music-tag-native-darwin-*"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
